<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1D9E75"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deal Detail"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- EMOJI HERO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#1D9E75"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/detailEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥛"
                android:textSize="72sp"/>

        </LinearLayout>

        <!-- MAIN CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_margin="16dp"
            android:elevation="4dp">

            <TextView
                android:id="@+id/detailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full cream milk 2L"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2C2C2A"
                android:layout_gravity="center_horizontal"/>

            <TextView
                android:id="@+id/detailStore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checkers • 1.2km away"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- PRICE ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#F5F5F5"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Now"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/detailPriceNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R24.99"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1D9E75"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="#EEEEEE"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#F5F5F5"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Was"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/detailPriceWas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R36.99"
                        android:textSize="26sp"
                        android:textColor="#AAAAAA"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="#EEEEEE"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#FCEBEB"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saving"
                        android:textSize="12sp"
                        android:textColor="#A32D2D"/>

                    <TextView
                        android:id="@+id/detailSaving"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="32% OFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#A32D2D"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- STORE INFO CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store info"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#2C2C2A"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏪"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/detailStoreName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Checkers"
                    android:textSize="14sp"
                    android:textColor="#2C2C2A"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="20sp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/detailDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2km away"
                    android:textSize="14sp"
                    android:textColor="#2C2C2A"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ADD TO BASKET BUTTON -->
        <TextView
            android:id="@+id/btnAddToBasket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛒 Add to Basket"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@color/cartlyGreen"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</ScrollView>